    ppltn_rate_60,
    ppltn_rate_70,
    resnt_ppltn_rate,
    non_resnt_ppltn_rate,
    replace_yn,
    ppltn_time,
    fcst_yn,
    raw_file_path,
    ingested_at
from ranked
where row_num = 1
    )
